{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "module": "ESNext",
    "target": "esnext",
    "moduleResolution": "bundler",
    "types": ["bun"],
    "paths": {
      "@/*": ["../frontend/*"],
      "$/*": ["./*"]
    },
    "plugins": [],
    "lib": ["ESNext"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}